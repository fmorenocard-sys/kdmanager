rules_version = '2'; // forced update to deploy to kdmanagerdb

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role;
    }
    
    function isKingOrOfficer() {
      return isAuthenticated() && (getUserRole() == 'King' || getUserRole() == 'Officer');
    }

    function isKing() {
      return isAuthenticated() && getUserRole() == 'King';
    }

    match /static_data/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Archived KvK campaigns (F-015). Public read like static_data;
    // only the King archives, and never over an existing campaign.
    // BR-012 (F-022): the King may set the official outcome afterwards —
    // update restricted to that single field so archives stay immutable.
    match /kvk_history/{kvkId} {
      allow read: if true;
      allow create: if isKing();
      allow update: if isKing()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['outcome']);
      allow delete: if false;
    }

    // KvK Race (E-005 / F-018-F-019). Lecture leadership uniquement (décision §9.4) ;
    // les agrégats sont écrits par les Cloud Functions (bypass rules). Le Roi édite
    // la config de campagne sur le document racine (US-016).
    match /kvk_race/{campaignId} {
      allow read: if isKingOrOfficer();
      allow create, update: if isKing();
      allow delete: if false;

      match /{document=**} {
        allow read: if isKingOrOfficer();
        allow write: if false;
      }
    }

    match /roles/{userId} {
      allow read: if true;
      allow write: if false;
    }

    match /user_profiles/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isKingOrOfficer());
      allow write: if isAuthenticated() && (isOwner(userId) || isKingOrOfficer());
    }

    match /kvk_config/{document} {
      allow read: if isAuthenticated();
      allow write: if isKingOrOfficer(); 
    }

    match /war_availabilities/{document} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isKingOrOfficer());
    }
    
    match /bank_deposits/{document} {
      allow read: if isAuthenticated();
      allow write: if isKingOrOfficer();
    }
    
    match /deadweight_list/{document} {
      allow read: if isAuthenticated();
      allow write: if isKingOrOfficer();
    }
  }
}
