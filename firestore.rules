rules_version = '2'; // forced update to deploy to kdmanagerdb

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role;
    }
    
    function isKingOrOfficer() {
      return isAuthenticated() && (getUserRole() == 'King' || getUserRole() == 'Officer');
    }

    match /static_data/{document=**} {
      allow read: if true;
      allow write: if false; 
    }

    match /roles/{userId} {
      allow read: if true;
      allow write: if false; 
    }

    match /user_profiles/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isKingOrOfficer());
      allow write: if isAuthenticated() && (isOwner(userId) || isKingOrOfficer());
    }

    match /kvk_config/{document} {
      allow read: if isAuthenticated();
      allow write: if isKingOrOfficer(); 
    }

    match /war_availabilities/{document} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isKingOrOfficer());
    }
    
    match /bank_deposits/{document} {
      allow read: if isAuthenticated();
      allow write: if isKingOrOfficer();
    }
    
    match /deadweight_list/{document} {
      allow read: if isAuthenticated();
      allow write: if isKingOrOfficer();
    }
  }
}
